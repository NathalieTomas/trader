# ══════════════════════════════════════════════════════════════
# NEXUS GEMHUNTER — Pool Listener Configuration
# ══════════════════════════════════════════════════════════════

# ── RPC Endpoints (WebSocket obligatoire pour le temps réel) ──
# Recommandé: Alchemy ou QuickNode (plan gratuit suffit pour commencer)
# Inscription: https://www.alchemy.com ou https://www.quicknode.com

# Ethereum Mainnet
ETH_WS_RPC=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Base
BASE_WS_RPC=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Arbitrum (optionnel)
# ARB_WS_RPC=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# Solana
SOLANA_WS_RPC=wss://api.mainnet-beta.solana.com
SOLANA_HTTP_RPC=https://api.mainnet-beta.solana.com
# Pour un RPC plus rapide (recommandé):
# SOLANA_WS_RPC=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# SOLANA_HTTP_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# ── Telegram Bot ──
# Crée un bot via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=

# ── Filtres ──
MIN_LIQUIDITY_USD=5000
MIN_SCORE=50

# ── Trading (future) ──
# FEE_WALLET=0x...           # Wallet qui reçoit les fees
# FEE_PCT=0.5                # Fee en % par trade
