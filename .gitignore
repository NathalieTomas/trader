# ══════════════════════════════════════════════════════════════
# NEXUS TRADER — .gitignore
# ══════════════════════════════════════════════════════════════

# ── Secrets (CRITIQUE — ne jamais push) ──
.env
*.env
!env.example
!*.env.example

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
venv/
.venv/

# ── Données locales ──
*.db
*.sqlite
*.sqlite3
data/
logs/
*.log

# ── Cache ──
.backtest_cache/
.cache/
*.cache

# ── IDE / Éditeurs ──
.claude/
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Docker volumes locaux ──
nexus-data/
nexus-logs/
nexus-cache/

# ── Node (pour le dashboard React) ──
node_modules/
package-lock.json

# ── OS ──
.DS_Store
Desktop.ini
ehthumbs.db
