# ══════════════════════════════════════════════════════════════
# NEXUS TRADER — Configuration complète
# Copie ce fichier en .env et remplis les valeurs
# ══════════════════════════════════════════════════════════════


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 1. BOT TRADING PERSO (bot.py)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Binance API ──
# Crée tes clés sur https://www.binance.com/en/my/settings/api-management
# IMPORTANT: Active uniquement "Enable Reading" et "Enable Spot Trading"
# Ne JAMAIS activer "Enable Withdrawals" !
BINANCE_API_KEY=ta_cle_api_ici
BINANCE_API_SECRET=ton_secret_ici

# ── Mode de trading ──
# paper = simulation avec données réelles (recommandé pour commencer)
# live  = trading réel avec de vrais fonds
TRADING_MODE=paper

# ── Paire de trading ──
TRADING_PAIR=BTC/USDT
BASE_CURRENCY=USDT
INITIAL_BALANCE=10000

# ── Logging ──
LOG_LEVEL=INFO


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 2. GEMHUNTER — Pool Listener (pool_listener.py)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── RPC Endpoints (WebSocket = temps réel, HTTP = transactions) ──
# Inscription gratuite: https://www.alchemy.com ou https://www.quicknode.com
# Ou Helius pour Solana: https://www.helius.dev

# Ethereum
ETH_WS_RPC=wss://eth-mainnet.g.alchemy.com/v2/M9viWxQrKCvbgvOTim2Qd
ETH_HTTP_RPC=https://eth-mainnet.g.alchemy.com/v2/M9viWxQrKCvbgvOTim2Qd

# Base
BASE_WS_RPC=wss://base-mainnet.g.alchemy.com/v2/M9viWxQrKCvbgvOTim2Qd
BASE_HTTP_RPC=https://base-mainnet.g.alchemy.com/v2/M9viWxQrKCvbgvOTim2Qd

# Arbitrum (optionnel)
# ARB_WS_RPC=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
# ARB_HTTP_RPC=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# Solana
SOLANA_WS_RPC=wss://api.mainnet-beta.solana.com
SOLANA_HTTP_RPC=https://api.mainnet-beta.solana.com
# Pour un RPC plus rapide (recommandé en prod):
# SOLANA_WS_RPC=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# SOLANA_HTTP_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# ── Filtres d'alertes ──
MIN_LIQUIDITY_USD=5000
MIN_SCORE=50

# ── Telegram Bot ──
# Crée un bot via @BotFather sur Telegram, copie le token
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 3. SWAP EXECUTOR (swap_executor.py)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Fee config ──
# Wallet qui reçoit les fees de chaque trade des users
FEE_WALLET_EVM=0x...
FEE_WALLET_SOLANA=...
FEE_PCT=0.8

# ── Chiffrement des clés privées des users ──
# Généré automatiquement au premier lancement si vide
# IMPORTANT: sauvegarde cette clé, sans elle les wallets users sont perdus
ENCRYPTION_KEY=UctGRHkOaEiVaaY5tw3ob5euDPI65u2pxiT1aGVjagk=


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 4. MODULES OPTIONNELS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── IA (intelligence.py + sentiment.py) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Sentiment ──
SENTIMENT_ENABLED=true
SENTIMENT_WEIGHT=0.3

# ── News Trading ──
NEWS_TRADING_ENABLED=true
NEWS_TRADING_AGGRESSIVENESS=medium

# ── Twitter/X (gemhunter social scan) ──
TWITTER_BEARER_TOKEN=

# ── On-chain APIs (optionnel) ──
ETHERSCAN_API_KEY=
MORALIS_API_KEY=

# ── Gem Hunter legacy (gemhunter.py) ──
GEM_AUTO_BUY=false
GEM_BET_SIZE=10
GEM_MAX_BETS=10
GEM_STOP_LOSS_PCT=30
GEM_TAKE_PROFIT_PCT=200
GEM_TRAILING_STOP_PCT=20
