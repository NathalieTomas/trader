# ══════════════════════════════════════════════════════════════
# NEXUS TRADER — Configuration
# ══════════════════════════════════════════════════════════════

# ── Binance API ──
# Crée tes clés sur https://www.binance.com/en/my/settings/api-management
# IMPORTANT: Active uniquement "Enable Reading" et "Enable Spot Trading"
# Ne JAMAIS activer "Enable Withdrawals" !
BINANCE_API_KEY=ta_cle_api_ici
BINANCE_API_SECRET=ton_secret_ici

# ── Mode de trading ──
# paper = simulation avec données réelles (recommandé pour commencer)
# live  = trading réel avec de vrais fonds
TRADING_MODE=paper

# ── Paire de trading ──
TRADING_PAIR=BTC/USDT

# ── Devise de base ──
BASE_CURRENCY=USDT

# ── Balance initiale pour le paper trading ──
INITIAL_BALANCE=10000

# ── Logging ──
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
